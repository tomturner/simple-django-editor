{
  "name": "simple-django-editor",
  "version": "1.0.2",
  "description": "A tiny IDE-style app for running Django servers inside Docker Compose — file tree, code editor, built-in Chromium browser, and terminal.",
  "main": "main.js",
  "author": "Tom Turner",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "codemirror": "^5.65.21",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tomturner.simpledjangoeditor",
    "productName": "Simple Django Editor",
    "asar": false,
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
